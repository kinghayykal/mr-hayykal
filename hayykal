<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Animasi Galaksi Interaktif | Three.js</title>
    <style>
        body {
            margin: 0;
            overflow: hidden;
            font-family: 'Segoe UI', 'Poppins', 'Arial', sans-serif;
        }
        #info {
            position: absolute;
            top: 20px;
            left: 20px;
            color: white;
            background: rgba(0,0,0,0.6);
            padding: 8px 16px;
            border-radius: 8px;
            backdrop-filter: blur(5px);
            pointer-events: none;
            z-index: 10;
            font-size: 14px;
            letter-spacing: 1px;
            box-shadow: 0 0 15px rgba(0,0,0,0.3);
            border-left: 3px solid #ff66cc;
        }
        #controls-hint {
            position: absolute;
            bottom: 20px;
            left: 20px;
            color: rgba(255,255,255,0.7);
            background: rgba(0,0,0,0.4);
            padding: 5px 12px;
            border-radius: 8px;
            font-size: 12px;
            font-family: monospace;
            pointer-events: none;
            z-index: 10;
        }
        @media (max-width: 600px) {
            #info { font-size: 10px; top: 10px; left: 10px; }
            #controls-hint { font-size: 8px; }
        }
    </style>
</head>
<body>
    <div id="info">
        ✨ GALAKSI SPIRAL INTERAKTIF ✨
    </div>
    <div id="controls-hint">
        🖱️ Geser untuk memutar kamera | ⚡ Scroll zoom
    </div>

    <!-- Import Three.js core dan add-ons dari CDN -->
    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.128.0/build/three.module.js",
                "three/addons/": "https://unpkg.com/three@0.128.0/examples/jsm/"
            }
        }
    </script>

    <script type="module">
        import * as THREE from 'three';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
        import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';
        import { RenderPass } from 'three/addons/postprocessing/RenderPass.js';
        import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';
        
        // --- Inisialisasi Scene, Camera, Renderer ---
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x010118); // warna hitam kebiruan deep space
        scene.fog = new THREE.FogExp2(0x010118, 0.0004); // kabut lembut untuk kedalaman

        // Kamera perspektif: field of view, aspect ratio, near, far
        const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 2000);
        camera.position.set(15, 8, 18);
        camera.lookAt(0, 0, 0);

        const renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(window.devicePixelRatio);
        renderer.toneMapping = THREE.ReinhardToneMapping;
        renderer.toneMappingExposure = 1.2;
        document.body.appendChild(renderer.domElement);

        // --- Effect Composer untuk Bloom (efek bercahaya) ---
        const renderScene = new RenderPass(scene, camera);
        const bloomPass = new UnrealBloomPass(new THREE.Vector2(window.innerWidth, window.innerHeight), 1.2, 0.3, 0.85);
        bloomPass.threshold = 0.1;  // intensitas mulai bloom
        bloomPass.strength = 0.8;
        bloomPass.radius = 0.5;
        const effectComposer = new EffectComposer(renderer);
        effectComposer.addPass(renderScene);
        effectComposer.addPass(bloomPass);

        // --- Kontrol Orbit untuk interaktivitas ---
        const controls = new OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;      // inertia
        controls.dampingFactor = 0.05;
        controls.rotateSpeed = 0.8;
        controls.zoomSpeed = 1.2;
        controls.enableZoom = true;
        controls.zoomSpeed = 1.0;
        controls.enablePan = false;
        controls.autoRotate = false;
        controls.target.set(0, 0, 0);
        
        // --- Bintang latar belakang (partikel jarak jauh) untuk efek space yang kaya ---
        const starGeometry = new THREE.BufferGeometry();
        const starCount = 3000;
        const starPositions = new Float32Array(starCount * 3);
        for (let i = 0; i < starCount; i++) {
            // Distribusi dalam radius besar, bentuk bola
            const radius = 300 + Math.random() * 200;
            const theta = Math.random() * Math.PI * 2;
            const phi = Math.acos(2 * Math.random() - 1);
            starPositions[i*3] = radius * Math.sin(phi) * Math.cos(theta);
            starPositions[i*3+1] = radius * Math.sin(phi) * Math.sin(theta);
            starPositions[i*3+2] = radius * Math.cos(phi);
        }
        starGeometry.setAttribute('position', new THREE.BufferAttribute(starPositions, 3));
        const starMaterial = new THREE.PointsMaterial({
            color: 0xffffff,
            size: 0.25,
            transparent: true,
            opacity: 0.7,
            blending: THREE.AdditiveBlending
        });
        const starsField = new THREE.Points(starGeometry, starMaterial);
        scene.add(starsField);
        
        // Tambahkan bintang kecil berwarna redup di sekitar (efek Milky Way samar)
        const starField2Geo = new THREE.BufferGeometry();
        const starCount2 = 2000;
        const starPos2 = new Float32Array(starCount2 * 3);
        for (let i = 0; i < starCount2; i++) {
            starPos2[i*3] = (Math.random() - 0.5) * 500;
            starPos2[i*3+1] = (Math.random() - 0.5) * 200;
            starPos2[i*3+2] = (Math.random() - 0.5) * 300 - 100;
        }
        starField2Geo.setAttribute('position', new THREE.BufferAttribute(starPos2, 3));
        const starMaterial2 = new THREE.PointsMaterial({ color: 0xaaccff, size: 0.15, transparent: true, opacity: 0.5, blending: THREE.AdditiveBlending });
        const starsField2 = new THREE.Points(starField2Geo, starMaterial2);
        scene.add(starsField2);
        
        // --- GALAKSI UTAMA: Sistem partikel spiral dengan warna gradien ---
        // Jumlah partikel untuk galaksi
        const particleCount = 45000;
        const geometry = new THREE.BufferGeometry();
        
        // Array posisi (xyz) dan warna (rgb)
        const positions = new Float32Array(particleCount * 3);
        const colors = new Float32Array(particleCount * 3);
        
        // Parameter spiral: lengan utama dan lengan sekunder, dengan sedikit noise
        
        // Warna dasar: inti kemerahan/keemasan, lengan biru/ungu kebiruan
        const centerColor = new THREE.Color(0xffaa66); // kuning keemasan
        const midColor = new THREE.Color(0xff66cc);   // magenta/pink
        const outerColor = new THREE.Color(0x66aaff); // biru terang
        
        for (let i = 0; i < particleCount; i++) {
            // Tentukan radius (dari pusat) dengan distribusi eksponensial agar lebih padat di tengah
            let r = Math.pow(Math.random(), 1.5) * 12; // radius maks 12 unit
            // Sedikit variasi untuk lengan yang lebih lebar
            const angleOffset = Math.random() * Math.PI * 2;
            
            // Jumlah lengan: 3 lengan utama + 2 lengan sekunder yang lebih redup
            let armChoice = Math.floor(Math.random() * 5); // 0-4
            let armAngleBase = 0;
            let intensity = 1;
            if (armChoice === 0) armAngleBase = 0;
            else if (armChoice === 1) armAngleBase = Math.PI * 2 / 3;
            else if (armChoice === 2) armAngleBase = Math.PI * 4 / 3;
            else if (armChoice === 3) armAngleBase = Math.PI / 3;  // lengan sekunder
            else armAngleBase = Math.PI + Math.PI / 3;
            
            // Untuk lengan sekunder (index 3 dan 4), kurangi sedikit kepadatan dan radius maks lebih kecil
            let maxR = 11;
            if (armChoice >= 3) {
                maxR = 9;
                intensity = 0.7;
                // sesuaikan radius agar tidak melebihi
                r = Math.pow(Math.random(), 1.8) * maxR;
            } else {
                r = Math.pow(Math.random(), 1.5) * maxR;
            }
            
            // Sudut spiral: logaritmik -> angle = offset + (r * faktor) + noise
            const spiralTightness = 0.9;  // kepadatan putaran
            let angle = armAngleBase + (r * spiralTightness);
            
            // Tambahkan noise untuk memberikan ketebalan alami pada lengan
            const noiseAngle = (Math.random() - 0.5) * 0.6;
            const radialNoise = (Math.random() - 0.5) * 0.35;
            const finalR = Math.max(0.1, r + radialNoise);
            const finalAngle = angle + noiseAngle;
            
            // Konversi ke koordinat kartesian (bidang XZ, dengan sedikit ketebalan vertikal)
            const x = Math.cos(finalAngle) * finalR;
            const z = Math.sin(finalAngle) * finalR;
            // Ketebalan disk: lebih tipis di pinggir, lebih tebal di tengah? Buat efek lenticular
            let y = (Math.random() - 0.5) * 0.35 * (1 - (finalR / 12) * 0.7);
            // Tambahkan sedikit warp pada lengan bagian luar
            if (finalR > 6) y += (Math.random() - 0.5) * 0.2;
            
            positions[i*3] = x;
            positions[i*3+1] = y;
            positions[i*3+2] = z;
            
            // --- Warna berdasarkan radius dan sedikit acak ---
            let mixColor;
            const t = finalR / 12; // 0 di pusat, 1 di tepi
            if (finalR < 2.5) {
                // inti keemasan dengan campuran oranye
                mixColor = centerColor.clone().lerp(midColor, Math.random() * 0.5);
            } else if (finalR < 7) {
                // transisi magenta ke biru
                const t2 = (finalR - 2.5) / 4.5;
                mixColor = midColor.clone().lerp(outerColor, t2);
            } else {
                mixColor = outerColor.clone();
                // tambahkan sedikit keunguan di ujung
                mixColor.lerp(new THREE.Color(0xaa88ff), 0.5);
            }
            
            // Variasi individual: lebih terang di lengan utama, sedikit lebih redup di sekunder
            let brightness = 0.8 + Math.random() * 0.6;
            if (armChoice >= 3) brightness *= 0.7;
            // partikel inti lebih terang
            if (finalR < 1.5) brightness = 1.0 + Math.random() * 0.5;
            
            colors[i*3] = mixColor.r * brightness;
            colors[i*3+1] = mixColor.g * brightness;
            colors[i*3+2] = mixColor.b * brightness;
        }
        
        geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));
        
        // Material untuk partikel galaksi: additive blending, ukuran berdasarkan jarak? Ukuran konstan dengan variasi
        const particleMaterial = new THREE.PointsMaterial({
            size: 0.08,
            vertexColors: true,
            blending: THREE.AdditiveBlending,
            transparent: true,
            opacity: 0.95
        });
        
        const galaxyParticles = new THREE.Points(geometry, particleMaterial);
        scene.add(galaxyParticles);
        
        // --- Tambahkan BINTANG INTI (glow core) dengan bola bercahaya dan lens flare palsu (Sprite)---
        const coreGeometry = new THREE.SphereGeometry(0.85, 32, 32);
        const coreMaterial = new THREE.MeshStandardMaterial({
            color: 0xffaa66,
            emissive: 0xff4422,
            emissiveIntensity: 1.2,
            roughness: 0.3,
            metalness: 0.8
        });
        const coreSphere = new THREE.Mesh(coreGeometry, coreMaterial);
        scene.add(coreSphere);
        
        // Lingkaran cahaya halo di sekitar inti (partikel kecil)
        const haloGeo = new THREE.BufferGeometry();
        const haloCount = 1800;
        const haloPos = [];
        for (let i = 0; i < haloCount; i++) {
            const rad = 1.2 + Math.random() * 0.8;
            const theta = Math.random() * Math.PI * 2;
            const phi = Math.acos(2 * Math.random() - 1);
            const x = rad * Math.sin(phi) * Math.cos(theta);
            const y = rad * Math.sin(phi) * Math.sin(theta) * 0.6; // sedikit pipih
            const z = rad * Math.cos(phi);
            haloPos.push(x, y, z);
        }
        haloGeo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(haloPos), 3));
        const haloMat = new THREE.PointsMaterial({ color: 0xffaa77, size: 0.04, blending: THREE.AdditiveBlending });
        const haloPoints = new THREE.Points(haloGeo, haloMat);
        scene.add(haloPoints);
        
        // --- Lengan debu / nebula tipis menggunakan partikel transparan tambahan (efek kabut)---
        const dustCount = 12000;
        const dustGeo = new THREE.BufferGeometry();
        const dustPositions = new Float32Array(dustCount * 3);
        const dustColorsArr = new Float32Array(dustCount * 3);
        for (let i = 0; i < dustCount; i++) {
            const r = Math.pow(Math.random(), 1.2) * 11;
            const armIdx = Math.floor(Math.random() * 3);
            let armAng = (armIdx * Math.PI * 2 / 3) + (r * 0.85);
            armAng += (Math.random() - 0.5) * 1.2;
            const x = Math.cos(armAng) * r;
            const z = Math.sin(armAng) * r;
            const y = (Math.random() - 0.5) * 0.6 * (1 - r/12);
            dustPositions[i*3] = x;
            dustPositions[i*3+1] = y;
            dustPositions[i*3+2] = z;
            // Warna debu: kebiruan/keunguan transparan
            const col = new THREE.Color(0x88aaff);
            const intensity = 0.35 + Math.random() * 0.4;
            dustColorsArr[i*3] = col.r * intensity;
            dustColorsArr[i*3+1] = col.g * intensity;
            dustColorsArr[i*3+2] = col.b * intensity;
        }
        dustGeo.setAttribute('position', new THREE.BufferAttribute(dustPositions, 3));
        dustGeo.setAttribute('color', new THREE.BufferAttribute(dustColorsArr, 3));
        const dustMat = new THREE.PointsMaterial({ size: 0.045, vertexColors: true, transparent: true, opacity: 0.4, blending: THREE.AdditiveBlending });
        const dustCloud = new THREE.Points(dustGeo, dustMat);
        scene.add(dustCloud);
        
        // --- Efek bintang jatuh / partikel berkilau (sparkle) ---
        const sparkleCount = 800;
        const sparkleGeo = new THREE.BufferGeometry();
        const sparklePositions = new Float32Array(sparkleCount * 3);
        for (let i = 0; i < sparkleCount; i++) {
            // Tersebar di area galaksi
            sparklePositions[i*3] = (Math.random() - 0.5) * 22;
            sparklePositions[i*3+1] = (Math.random() - 0.5) * 3;
            sparklePositions[i*3+2] = (Math.random() - 0.5) * 22;
        }
        sparkleGeo.setAttribute('position', new THREE.BufferAttribute(sparklePositions, 3));
        const sparkleMat = new THREE.PointsMaterial({ color: 0xffdd99, size: 0.05, transparent: true, blending: THREE.AdditiveBlending });
        const sparkles = new THREE.Points(sparkleGeo, sparkleMat);
        scene.add(sparkles);
        
        // --- Animasi rotasi keseluruhan untuk galaksi (opsional, tapi biarkan partikel berputar perlahan)---
        // Kita akan membuat grup yang berisi semua elemen galaksi (partikel, debu, halo, core) agar bisa memutar secara halus
        const galaxyGroup = new THREE.Group();
        galaxyGroup.add(galaxyParticles);
        galaxyGroup.add(dustCloud);
        galaxyGroup.add(haloPoints);
        galaxyGroup.add(coreSphere);
        galaxyGroup.add(sparkles);
        scene.add(galaxyGroup);
        
        // Juga tambahkan beberapa bintang terang besar (Sprite) sebagai efek lens flare sederhana? 
        // Menggunakan titik cahaya besar dengan additive blending
        const bigStarsGeo = new THREE.BufferGeometry();
        const bigStarsPos = [];
        for (let i = 0; i < 150; i++) {
            const rad = 13 + Math.random() * 8;
            const theta = Math.random() * Math.PI * 2;
            const phi = Math.acos(2 * Math.random() - 1);
            const x = rad * Math.sin(phi) * Math.cos(theta);
            const y = rad * Math.sin(phi) * Math.sin(theta) * 0.5;
            const z = rad * Math.cos(phi);
            bigStarsPos.push(x, y, z);
        }
        bigStarsGeo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(bigStarsPos), 3));
        const bigStarMat = new THREE.PointsMaterial({ color: 0xffccaa, size: 0.12, transparent: true, blending: THREE.AdditiveBlending });
        const bigStars = new THREE.Points(bigStarsGeo, bigStarMat);
        scene.add(bigStars);
        
        // --- Cahaya Ambient dan sumber cahaya untuk memberikan dimensi pada inti---
        const ambientLight = new THREE.AmbientLight(0x111122);
        scene.add(ambientLight);
        const pointLight = new THREE.PointLight(0xffaa66, 1.2, 30);
        pointLight.position.set(0, 0.5, 0);
        scene.add(pointLight);
        
        // Sedikit cahaya dari belakang untuk efek
        const backLight = new THREE.PointLight(0x4466ff, 0.5);
        backLight.position.set(-2, 1, -3);
        scene.add(backLight);
        
        // --- Animasi partikel sparkle berkedip (mengubah ukuran atau opacity secara dinamis)---
        // Kita akan membuat array waktu acak untuk setiap sparkle (tidak perlu vertex shader kompleks, cukup update material opacity global? Tapi lebih bagus efek berkedip)
        // Untuk sederhananya, kita akan memutar galaxyGroup perlahan dan membuat beberapa efek berdenyut pada core dan halo
        
        // Variabel untuk efek denyut inti
        let time = 0;
        
        // Juga animasi rotasi grup galaksi dengan kecepatan sangat lambat (berbeda arah untuk kedalaman)
        // Dan bintang latar belakang sedikit bergerak (parallax lembut) dengan rotasi kamera? Tidak perlu, cukup rotasi galaksi
        
        // Untuk efek dinamis pada sparkle, kita akan mengubah ukuran partikel secara acak setiap frame? Tidak efisien.
        // Alternatif: putar grup, dan secara periodik mengubah intensitas core dan warna.
        
        // --- Animasi tambahan: partikel debu berputar perlahan relatif terhadap galaksi, tapi karena sudah dalam grup, cukup rotasi grup ---
        
        // Kecepatan rotasi galaksi
        let galaxyRotationSpeed = 0.0012;
        
        // Buat beberapa partikel bergerak sendiri (meteor/bintang jatuh) tidak diperlukan, cukup efek keren.
        
        // --- Render loop ---
        function animate() {
            requestAnimationFrame(animate);
            
            time += 0.016; // kira-kira per frame
            
            // Rotasi galaksi secara perlahan untuk efek dinamis
            galaxyGroup.rotation.y += galaxyRotationSpeed;
            // Sedikit rotasi pada sumbu X agar terlihat miring natural
            galaxyGroup.rotation.x = Math.sin(time * 0.1) * 0.05;
            galaxyGroup.rotation.z = Math.cos(time * 0.13) * 0.03;
            
            // Efek denyut inti: mengubah intensitas emissive dan skala sedikit
            const pulse = 0.85 + Math.sin(time * 3) * 0.08;
            coreMaterial.emissiveIntensity = 0.9 + Math.sin(time * 4.2) * 0.25;
            // Ubah warna halo sedikit
            const huePulse = 0.5 + Math.sin(time * 1.8) * 0.1;
            haloMat.color.setHSL(0.12, 1.0, 0.65);
            
            // Sparkle berkedip dengan mengubah opacity material secara global (efek simple)
            const sparkleOpacity = 0.6 + Math.sin(time * 5) * 0.3;
            sparkleMat.opacity = sparkleOpacity;
            
            // Rotasi bintang latar sangat lambat untuk memberikan sensasi pergerakan kosmos
            starsField.rotation.y += 0.0002;
            starsField2.rotation.x += 0.0001;
            bigStars.rotation.y -= 0.00015;
            
            // Perbesar efek glow dengan bloom strength halus berubah
            bloomPass.strength = 0.75 + Math.sin(time * 0.7) * 0.08;
            
            // Update kontrol dan composer
            controls.update(); // update orbit jika ada interaksi
            
            // Render melalui EffectComposer untuk bloom
            effectComposer.render();
        }
        
        animate();
        
        // --- Resize handler ---
        window.addEventListener('resize', onWindowResize, false);
        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
            effectComposer.setSize(window.innerWidth, window.innerHeight);
        }
        
        // Sedikit efek acak untuk menambah 'kedipan' pada partikel debu (optional: mengubah warna acak beberapa partikel setiap beberapa detik, tidak perlu karena sudah kaya)
        
        console.log('Animasi Galaksi Siap | Nikmati keindahan kosmos!');
    </script>
</body>
</html>
